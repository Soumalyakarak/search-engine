<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DSA Search Activation Email</title>
    <style type="text/css">
     
     body{
        margin: 0;
        padding: 0;
        min-width: 100%;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        background-color: #fafafa;
        color: #2222;
     }

     a {
        color: #000;
        text-decoration: none;
     }
     h1 {
        font-size: 24px;
        line-height: 1.25;
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 15px;
        text-align: center;
     }
     p {
       margin-top: 0;
       margin-bottom: 24px;
     }
     table td {
        vertical-align: top;
     }
     /* Layout */
     .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
     }

     .email-header {
        background-color: blue;
        padding: 24px;
        color: #ffffff;
     }
     .email-body {
        background-color: #ffffff;
        padding: 24px;
        
     }
     .email-footer {
        background-color: #f6f6f6;
        padding: 24px;
        
     }

     /* Buttons */
     .button {
        display: inline-block;
        background-color: blue;
        color:#ffffff;
        font-size: 16px;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 4px;
     }
    </style>
</head>
<body>
   <div class="email-wrapper">
      <div class="email-header">
         <h1>Welcome to DSA Search</h1>
      </div>
      <div class="email-body">
         <p>Hello <%= name %>,</p>
         <p>
            Thank you for registering with DSA Search.To activate your account, please use the following activation code:
         </p>
         <h2><%= otp %></h2>
         <p>
            please enter this code on the activation page within the next 5 minutes.
         </p>
         <p>
            If you did not register for a Eshop account, please ignore this email.
         </p>
      </div>
      <div class="email-footer">
         <p>
            If you have any questions,please don't hesitate to contact us at
            <a href="mailto:soumalyakarak2@gmail.com">support@dsa-search.com</a>
         </p>
      </div>
   </div>
    
</body>
</html>